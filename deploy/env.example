# easy-reviews — production environment for the EC2 box.
# Copy to /opt/apps/reviews/.env, fill in real values, then `chmod 600 .env`.
# (Named env.example, not .env.example, so it isn't caught by the repo .gitignore.)
#
# This file is ALSO read by `docker compose` for ${VAR} interpolation in
# docker-compose.yml (AWS_ACCOUNT_ID, AWS_REGION, TAG) — so it serves double duty.

# ── Image / registry (used by docker-compose.yml interpolation) ──
AWS_ACCOUNT_ID=390403864981
AWS_REGION=us-east-1
# Image tag to run. `/opt/apps/scripts/deploy.sh reviews <tag>` rewrites this line.
TAG=latest

# ── App runtime config ──
# SQLite path is forced to the volume by docker-compose.yml; keep this in sync.
DATABASE_URL=file:/data/app.db
# Public base URL. Also baked into the client bundle at BUILD time (build-arg) —
# keep this equal to the --build-arg NEXT_PUBLIC_APP_URL used to build the image.
NEXT_PUBLIC_APP_URL=https://reviews.bakeoff.app

# ── Secrets (REQUIRED for the core flow) — keep this file chmod 600 ──
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
GOOGLE_API_KEY=

# ── Optional: accounts & saved history (anonymous-first; app works without) ──
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=https://reviews.bakeoff.app
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
